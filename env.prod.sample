# ================================================================
# MẪU cấu hình production cho VPS. Copy thành `.env` rồi điền giá trị THẬT.
#   cp env.prod.sample .env && nano .env
# KHÔNG commit file .env (đã nằm trong .gitignore).
# ================================================================

# ---- Database (Postgres tự host trong docker-compose) ----
POSTGRES_USER=keo
POSTGRES_PASSWORD=            # đặt mật khẩu mạnh, ngẫu nhiên
POSTGRES_DB=keo
# DATABASE_URL được compose tự dựng từ 3 biến trên (nội bộ @db:5432) — không cần set.

# ---- Bảo mật (BẮT BUỘC ở prod — thiếu là app tự thoát) ----
JWT_SECRET=                   # chuỗi ngẫu nhiên dài; ký JWT app (Zalo/Google)
TOKEN_CIPHER_KEY=             # base64 của 32 byte ngẫu nhiên: openssl rand -base64 32

# ---- Google OAuth (đăng nhập Google) ----
GOOGLE_OAUTH_CLIENT_ID=550781100457-t0pg0qf5bgrpejse9r5sne03dcd83k3e.apps.googleusercontent.com

# ---- Zalo OAuth (đăng nhập Zalo) ----
ZALO_APP_ID=
ZALO_SECRET_KEY=

# ---- Strava (BẮT BUỘC ở prod: SECRET + VERIFY_TOKEN) ----
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=
STRAVA_SUBSCRIPTION_ID=

# ---- SePay (nạp điểm — BẮT BUỘC: API_KEY) ----
SEPAY_API_KEY=
SEPAY_ACCOUNT_NO=
SEPAY_BANK_CODE=MB

# ---- Tuỳ chọn ----
# FIREBASE_APP_ID=            # chỉ cần nếu dùng health-sync mobile (App Check)
